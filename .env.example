# Copie ce fichier en .env.local et renseigne ta clé Mistral.
MISTRAL_API_KEY=

# Optionnel — surcharge des modèles :
MISTRAL_VISION_MODEL=pixtral-large-latest
MISTRAL_TEXT_MODEL=mistral-large-latest

# Rendu IA avant/après — deux fournisseurs possibles (Gemini essayé en 1er) :
#
# Google Gemini (palier GRATUIT, sans carte bancaire) — recommandé :
#   clé à créer sur https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-image
#
# Replicate (payant, repli si Gemini absent/échoue) :
REPLICATE_API_TOKEN=
# REPLICATE_MODEL=black-forest-labs/flux-kontext-pro

# Whop (paiement) :
WHOP_API_KEY=
# Lien de checkout Whop (public, exposé au client) :
NEXT_PUBLIC_WHOP_CHECKOUT_URL=

# Paiement — prestataire actif : stripe | whop | demo (défaut: stripe)
NEXT_PUBLIC_PAYMENT_PROVIDER=stripe

# Stripe :
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# STRIPE_MODE=subscription
# NEXT_PUBLIC_SITE_URL=https://new-saa-s.vercel.app

# Supabase (comptes + base de données + photos) :
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Serveur uniquement (webhook, tâches admin) — ne JAMAIS exposer côté client :
SUPABASE_SERVICE_ROLE_KEY=

# Resend (emails de bienvenue + rappels quotidiens) :
RESEND_API_KEY=
# Expéditeur — passe à "Capilatyx <hello@capilatyx.website>" une fois le
# domaine vérifié dans Resend ; sinon laisse vide (onboarding@resend.dev).
EMAIL_FROM=
# Secret partagé qui protège le cron de rappels (mets la même valeur dans Vercel) :
CRON_SECRET=

# Pexels (photos du catalogue de coupes — sert au seeding, pas au runtime) :
PEXELS_API_KEY=
